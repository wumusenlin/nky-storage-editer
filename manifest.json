{
  "manifest_version": 3,
  "name": "NKY-Storage-Editor",
  "version": "1.0",
  "description": "Manage localStorage and sessionStorage across neikongyi.com subdomains.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "*://neikongyi.com/*",
    "*://*.neikongyi.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://neikongyi.com/*",
        "*://*.neikongyi.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content_scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
